# Application Configuration
APP_NAME="PropAI - AI Agent as a Service"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_ARTISAN_KEY_GENERATOR=
APP_DEBUG=false
APP_URL=https://your-railway-app.railway.app
APP_TIMEZONE=Asia/Singapore

# Locale Settings
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Security
BCRYPT_ROUNDS=12

# Logging Configuration
LOG_CHANNEL=errorlog
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration (SQLite for Railway)
DB_CONNECTION=sqlite
DB_DATABASE=/app/data/database.sqlite

# Alternative Database Configurations (if using MySQL/PostgreSQL on Railway)
# DB_CONNECTION=mysql
# DB_HOST=${{SECRETS_DB_HOST}}
# DB_PORT=3306
# DB_DATABASE=${{SECRETS_DB_NAME}}
# DB_USERNAME=${{SECRETS_DB_USER}}
# DB_PASSWORD=${{SECRETS_DB_PASSWORD}}

# Session Configuration
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIES=false

# Broadcasting & Queues
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=file
CACHE_PREFIX=

# Memory Cache (optional)
MEMCACHED_HOST=127.0.0.1

# Redis (optional - for advanced caching/sessions)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration (default to log for testing)
MAIL_MAILER=log
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@propai.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 (optional - for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite Configuration
VITE_APP_NAME="${APP_NAME}"

# Stripe Configuration (Payment Processing)
STRIPE_KEY=pk_test_YOUR_STRIPE_PUBLIC_KEY
STRIPE_SECRET=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_WEBHOOK_URL=/api/webhooks/stripe
STRIPE_PRODUCT_ID_BASIC=prod_basic_bundle
STRIPE_PRICE_ID_BASIC=price_basic_monthly
STRIPE_PRODUCT_ID_PRO=prod_pro_bundle
STRIPE_PRICE_ID_PRO=price_pro_monthly
STRIPE_PRODUCT_ID_ENTERPRISE=prod_enterprise_bundle
STRIPE_PRICE_ID_ENTERPRISE=price_enterprise_monthly

# Nebula Configuration (AI Agent Platform)
NEBULA_BASE_URL=https://api.nebula.ai
NEBULA_API_KEY=YOUR_NEBULA_API_KEY
NEBULA_WEBHOOK_SECRET=YOUR_NEBULA_WEBHOOK_SECRET
NEBULA_WEBHOOK_URL=/api/webhooks/nebula

# Telegram Configuration (Agent Integrations)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_API_URL=https://api.telegram.org/bot

# Gmail Configuration (optional - for email agent integrations)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send

# Mailgun (Transactional Email Service)
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net

# Postmark (Alternative Email Service)
POSTMARK_TOKEN=

# Resend (Modern Email API)
RESEND_KEY=

# Slack Notifications (optional)
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# Discord Webhook (optional - for notifications)
DISCORD_WEBHOOK_URL=

# Sentry Error Tracking (optional)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.01

# Telescope Debugging (development only - disable in production)
TELESCOPE_ENABLED=false

# Horizon Queue Dashboard (optional)
HORIZON_DOMAIN=null
HORIZON_PASSWORD=null

# Rate Limiting
RATE_LIMIT_API=60
RATE_LIMIT_WEB=120

# CORS Configuration
CORSPREFLIGHT_CACHE=0
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-CSRF-TOKEN
CORS_EXPOSED_HEADERS=
CORS_SUPPORTS_CREDENTIALS=false

# Trust Proxies (important for Railway)
TRUSTED_PROXIES=*

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/
